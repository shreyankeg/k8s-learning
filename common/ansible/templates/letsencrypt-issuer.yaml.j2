---
# Let's Encrypt ClusterIssuer — used by cert-manager to issue TLS certs
# for Ingress resources annotated with cert-manager.io/cluster-issuer.
#
# RKE2 applies any Kubernetes manifest in the server manifests dir, not
# just HelmChart CRs. If cert-manager's CRDs aren't ready yet, RKE2
# retries until they are.
#
# Rendered by deploy-keycloak.yml — do not edit on the node.

apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: letsencrypt-prod
spec:
  acme:
    server: https://acme-v02.api.letsencrypt.org/directory
    email: "{{ letsencrypt_email }}"
    privateKeySecretRef:
      name: letsencrypt-prod
    solvers:
      - http01:
          ingress:
            ingressClassName: "{{ ingress_class | default('traefik') }}"
