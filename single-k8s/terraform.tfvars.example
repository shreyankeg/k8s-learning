# Copy this file to terraform.tfvars and fill in your real values.
# terraform.tfvars is gitignored — credentials will never be committed.

# ── AWS credentials ───────────────────────────────────────────────────────────
aws_access_key = "AKIAIOSFODNN7EXAMPLE"
aws_secret_key = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
aws_region     = "us-east-1"

# ── VPC ───────────────────────────────────────────────────────────────────────
vpc_name             = "main"
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]

# ── SSH key pair ──────────────────────────────────────────────────────────────
key_name = "ec2-key"   # private key saved to keys/ec2-key.pem after apply

# ── EC2 instances ─────────────────────────────────────────────────────────────
# Amazon Linux 2023 in us-east-1 — find the correct ID for other regions at:
# https://aws.amazon.com/amazon-linux-ami/
ami_id               = "ami-0c02fb55956c7d316"
instance_type        = "t3a.medium"
instance_name_prefix = "ec2-node"

# Restrict SSH to your own IP for better security:
# ssh_allowed_cidrs = ["YOUR_PUBLIC_IP/32"]
ssh_allowed_cidrs = ["0.0.0.0/0"]

# ── Shared tags ───────────────────────────────────────────────────────────────
tags = {
  Environment = "dev"
  Project     = "k8s-test"
}
